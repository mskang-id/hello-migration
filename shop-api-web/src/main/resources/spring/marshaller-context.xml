<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
         http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="jaxbMarshaller" class="org.springframework.oxm.jaxb.Jaxb2Marshaller">
        <property name="packagesToScan">
            <list>
                <value>com.shopmall.common.envelope</value>
                <value>com.shopmall.common.vo</value>
                <value>com.shopmall.web.dto.product</value>
                <value>com.shopmall.web.dto.order</value>
                <value>com.shopmall.web.dto.member</value>
                <value>com.shopmall.web.dto.delivery</value>
                <value>com.shopmall.web.dto.report</value>
                <value>com.shopmall.web.dto.cart</value>
                <value>com.shopmall.web.dto.promotion</value>
                <value>com.shopmall.web.dto.review</value>
                <value>com.shopmall.web.dto.wishlist</value>
                <value>com.shopmall.web.dto.adminreport</value>
                <value>com.shopmall.web.dto.lifecycle</value>
            </list>
        </property>
    </bean>

    <bean id="marshallingConverter"
          class="org.springframework.http.converter.xml.MarshallingHttpMessageConverter">
        <property name="marshaller"   ref="jaxbMarshaller"/>
        <property name="unmarshaller" ref="jaxbMarshaller"/>
    </bean>
</beans>
